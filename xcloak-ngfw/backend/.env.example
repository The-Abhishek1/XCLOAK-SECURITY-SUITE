# ── Database ──────────────────────────────────────────────────

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=xcloak
DB_PASSWORD=
DB_NAME=ngfw

# ── Security — REQUIRED ───────────────────────────────────────

JWT_SECRET=
METRICS_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AI Provider ───────────────────────────────────────────────

ANTHROPIC_API_KEY=""
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_URL=http://localhost:11434

# ── Redis (rate limiting + token revocation) ───────────────────

REDIS_ADDR=localhost:6379

# ── Kafka ─────────────────────────────────────────────────────

KAFKA_BROKER=localhost:9092
KAFKA_ENABLED=true

# ── Email Alerts (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=xcloak-alerts@admin.com
