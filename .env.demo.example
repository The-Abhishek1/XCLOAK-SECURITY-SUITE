# Demo environment — copy to .env.demo and fill in secrets
# Usage: docker compose -f docker-compose.demo.yml --env-file .env.demo up -d --build

# ── Database ──────────────────────────────────────────────────
DB_USER=xcloak
DB_PASSWORD=change_me_strong_password
DB_NAME=xcloak_demo

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_64_hex_chars

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://suite.xcloak.tech

# ── Observability ─────────────────────────────────────────────
# Token Prometheus uses when scraping /metrics
METRICS_TOKEN=change_me_metrics_token
GRAFANA_PASSWORD=change_me_grafana_password
