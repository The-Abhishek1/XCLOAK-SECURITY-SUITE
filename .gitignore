# ── Secrets & local config ────────────────────────────────────────────────────
.env
*.env
prometheus/metrics_token
backups/
.claude/
.env.demo

# ── Build artifacts ───────────────────────────────────────────────────────────
**/tmp/main
**/tmp/build-errors.log
tmp/

# ── Compiled binaries — never commit ─────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
# eBPF compiled objects (*.o excluded, but bpf2go-generated objects in
# xcloak-agent-desktop/agent/ebpf/ must be committed — embedded at compile time)
*.o
!xcloak-agent-desktop/agent/ebpf/*.o
# Go build output
dist/
**/dist/
*.out

# ── Agent runtime files ───────────────────────────────────────────────────────
**/agent.token

# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
