# XCloak HA Stack — environment variables
# Copy to .env.ha and set all required values before starting.
#
#   cp .env.ha.example .env.ha
#   docker compose -f docker-compose.ha.yml --env-file .env.ha up -d --build

# ── Database ──────────────────────────────────────────────────────────────────
# Credentials used for both the postgres superuser and the backend connection.
DB_USER=xcloak
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=ngfw

# Password for the Postgres streaming replication user (replicator).
REPLICATION_PASSWORD=CHANGE_ME_replication_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Security ─────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars

# Token required by Prometheus to scrape /api/metrics
METRICS_TOKEN=CHANGE_ME_metrics_token

# Comma-separated list of allowed CORS origins (your frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Use Ollama (local):
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434

# Or use Claude (Anthropic). Uncomment and set your key:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ─────────────────────────────────────────────────────────────────
KAFKA_ENABLED=false

# ── Agent self-update signing ─────────────────────────────────────────────────
# Enables signed automatic agent binary updates via the backend's release API.
# Generate a keypair (one-time, store the private key securely):
#   openssl genpkey -algorithm ed25519 -out signing.pem
#   SEED=$(openssl pkey -in signing.pem -outform DER | tail -c 32 | base64 | tr '+/' '-_' | tr -d '=')
#   PUB=$(openssl pkey -in signing.pem -pubout -outform DER | tail -c 32 | base64 | tr '+/' '-_' | tr -d '=')
# AGENT_RELEASE_SIGNING_KEY: 32-byte ed25519 seed, base64url, no padding
# AGENT_RELEASE_PUBLIC_KEY:  matching public key (also injected into agent at build time)
# AGENT_RELEASE_CI_TOKEN:    shared token for the GitHub Actions release pipeline
#AGENT_RELEASE_SIGNING_KEY=CHANGE_ME
#AGENT_RELEASE_PUBLIC_KEY=CHANGE_ME
#AGENT_RELEASE_CI_TOKEN=CHANGE_ME

# ── License (your server — the license authority) ────────────────────────────
# Set SKIP_LICENSE_CHECK=true on YOUR server so it doesn't phone home to itself.
SKIP_LICENSE_CHECK=true

# ── License key signing (server that issues license keys) ─────────────────────
# Used by your license authority (your server) to sign license keys for customers.
# Falls back to AGENT_RELEASE_SIGNING_KEY when not set — generate a separate key
# for production so each can be rotated independently:
#   openssl genpkey -algorithm ed25519 -out license-signing.pem
#   SEED=$(openssl pkey -in license-signing.pem -outform DER | tail -c 32 | base64 | tr '+/' '-_' | tr -d '=')
#   PUB=$(openssl pkey -in license-signing.pem -pubout -outform DER | tail -c 32 | base64 | tr '+/' '-_' | tr -d '=')
#LICENSE_SIGNING_KEY=CHANGE_ME
#LICENSE_PUBLIC_KEY=CHANGE_ME

# ── License key (self-hosted customer deployments) ────────────────────────────
# Set this on CUSTOMER deployments (not on your own server). Obtain a key from
# the platform admin UI (Platform → Deployment Mode → Generate Key).
# When LICENSE_MODE enforcement is off (the default) this env var is ignored.
#XCLOAK_LICENSE_KEY=xlk_v1....
