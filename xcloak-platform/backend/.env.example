# ── Database ──────────────────────────────────────────────────

DB_HOST=127.0.0.1
DB_PORT=5432

# DB_USER is the schema owner used by the migration runner (needs DDL rights).
DB_USER=xcloak
DB_PASSWORD=
DB_NAME=ngfw

# APP_DB_USER / APP_DB_PASSWORD — the limited-privilege application role that
# connects for normal API queries. Set to a role created by migration 000050
# (xcloak_app) so PostgreSQL Row-Level Security is actually load-bearing rather
# than decorative. Falls back to DB_USER when not set (backward-compatible).
APP_DB_USER=xcloak_app
APP_DB_PASSWORD=

# ── Security — REQUIRED ───────────────────────────────────────

JWT_SECRET=
METRICS_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AI Provider ───────────────────────────────────────────────

ANTHROPIC_API_KEY=""
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_URL=http://localhost:11434

# ── Redis (rate limiting + token revocation) ───────────────────

REDIS_ADDR=localhost:6379

# ── MinIO (immutable audit log export) ─────────────────────────

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_AUDIT_BUCKET=xcloak-audit-log
MINIO_USE_SSL=false
AUDIT_EXPORT_RETENTION_DAYS=365

# ── Kafka ─────────────────────────────────────────────────────

KAFKA_BROKER=localhost:9092
KAFKA_ENABLED=false

# ── Email Alerts (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=xcloak-alerts@yourdomain.com
# SMTP_TLS=true  # set to true for port 465 (implicit TLS); leave unset for 587 STARTTLS

# Public URL of the frontend — used in email CTAs. Must be reachable by recipients.
APP_URL=https://suite.xcloak.tech
