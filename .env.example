# Read by `docker compose` (docker-compose.yml) for the Grafana service.
# Copy to .env and fill in to enable Grafana's email alert notifications —
# without this, the rules in grafana/provisioning/alerting/rules.yml
# evaluate and show in Grafana's UI but never notify anyone.
# Also edit the recipient address(es) in
# grafana/provisioning/alerting/contactpoints.yaml.

GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=xcloak-alerts@yourdomain.com
