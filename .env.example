# XCloak — environment template
# Copy to .env and fill in values before running docker compose up -d --build
#
# Used by:  docker-compose.yml  (full production stack)
# NOT used by quickstart — it bakes secrets at install time via install.sh

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=xcloak
DB_PASSWORD=change_me_strong_password
DB_NAME=ngfw

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_64_hex_chars

# ── Frontend ──────────────────────────────────────────────────────────────────
# Must match the URL your users hit in the browser (used for CORS and email links)
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
# REDIS_PASSWORD=

# ── Observability ─────────────────────────────────────────────────────────────
# Bearer token Prometheus uses when scraping /metrics
METRICS_TOKEN=change_me_metrics_token

# ── MinIO (audit log export) ──────────────────────────────────────────────────
MINIO_ACCESS_KEY=xcloak-minio
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_AUDIT_BUCKET=xcloak-audit-log
MINIO_USE_SSL=false
AUDIT_EXPORT_RETENTION_DAYS=365

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Set to true if you have a Kafka cluster; leave false for simple deployments
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:29092

# ── AI ────────────────────────────────────────────────────────────────────────
# Use Ollama (local) or Anthropic (cloud). Ollama requires a running instance.
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:3b

# To use Claude instead:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Grafana SMTP alerts ───────────────────────────────────────────────────────
# Without this, Grafana alert rules evaluate but never send notifications.
# Also edit grafana/provisioning/alerting/contactpoints.yaml to set recipients.
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=xcloak-alerts@yourdomain.com

# ── Agent self-update signing ─────────────────────────────────────────────────
# Optional. Generate: openssl rand 32 | base64 | tr '+/' '-_' | tr -d '='
# AGENT_RELEASE_SIGNING_KEY=
# AGENT_RELEASE_PUBLIC_KEY=
# AGENT_RELEASE_REQUIRE_SIGNATURE=false
# AGENT_RELEASE_CI_TOKEN=

# ── TLS (terminate at ingress instead — leave empty unless doing backend TLS) ─
# TLS_CERT_FILE=
# TLS_KEY_FILE=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FORMAT=json   # uncomment for structured JSON logs (recommended in prod)
