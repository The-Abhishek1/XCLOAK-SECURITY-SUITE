# XCloak — Aurora PostgreSQL Serverless v2 configuration
#
# Use this when deploying to AWS with Aurora PostgreSQL.
# Aurora provides auto-scaling compute (0.5–128 ACUs), 15 read replicas,
# continuous backup to S3, and ~30s automatic failover.
#
# Setup steps:
#   1. Create an Aurora PostgreSQL Serverless v2 cluster in RDS console
#   2. Enable Data API or VPC peering so your ECS/EKS task can reach the cluster
#   3. Create the application DB and user:
#        CREATE DATABASE ngfw;
#        CREATE USER xcloak WITH PASSWORD '...';
#        GRANT ALL PRIVILEGES ON DATABASE ngfw TO xcloak;
#   4. Download the AWS global bundle cert:
#        curl -o rds-ca.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
#   5. Mount rds-ca.pem into your container at /certs/rds-ca.pem
#   6. Set the env vars below in your ECS task definition / Kubernetes secret

# ── Primary (writer) endpoint ─────────────────────────────────────────────────
# Aurora writer endpoint — always points to the current primary instance.
DB_HOST=your-cluster.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=xcloak
DB_PASSWORD=CHANGE_ME
DB_NAME=ngfw

# ── Read replica (reader) endpoint ────────────────────────────────────────────
# Aurora reader endpoint — load-balances across all read replicas.
# XCloak sends SELECT queries here when DB_READ_HOST is set.
DB_READ_HOST=your-cluster.cluster-ro-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_READ_PORT=5432
# DB_READ_USER and DB_READ_PASSWORD fall back to DB_USER/DB_PASSWORD when unset.

# ── TLS (required for Aurora) ─────────────────────────────────────────────────
DB_SSLMODE=require
DB_SSLROOTCERT=/certs/rds-ca.pem
# DB_SSLCERT and DB_SSLKEY are only needed for mutual TLS (not required by Aurora).

# ── Redis (use ElastiCache) ───────────────────────────────────────────────────
REDIS_ADDR=your-elasticache.xxxxxx.cache.amazonaws.com:6379
# REDIS_PASSWORD= (set if auth token enabled on ElastiCache)

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_32_chars
METRICS_TOKEN=CHANGE_ME

# Restrict CORS to your actual frontend domain
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── AI / LLM ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
KAFKA_ENABLED=false
# KAFKA_BROKERS=b-1.your-msk-cluster.amazonaws.com:9092,...

# TimescaleDB note:
# Aurora is a PostgreSQL-compatible managed service and does NOT support
# the TimescaleDB extension. The 000067_timescaledb.up.sql migration
# detects this at runtime and skips silently — no action needed.
# Use the HA Patroni stack (docker-compose.ha.yml) with timescale/timescaledb-ha:pg16
# if you need TimescaleDB compression and retention policies on self-hosted infra.
